# Copy to `.env.local` for local Supabase. After `npm run db:start`, run `npm run db:status`
# and paste the API URL and anon key below. Vite loads `.env.local` automatically.

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=paste_anon_key_from_db_status

# Optional: hide Google when testing a production build against local Supabase (rare).
# VITE_HIDE_GOOGLE_AUTH=true
