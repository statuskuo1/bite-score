# Copy to `.env.local` for local Supabase. After `npm run db:start`, run `npm run db:status`
# and paste the API URL and anon key below. Vite loads `.env.local` automatically.

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=paste_anon_key_from_db_status

# Optional: hide Google when testing a production build against local Supabase (rare).
# VITE_HIDE_GOOGLE_AUTH=true

# ---------------------------------------------------------------------------
# Google Places verification (Edge Function secrets — NOT shipped to browser)
# ---------------------------------------------------------------------------
# These are read by `supabase/functions/places-search` + `places-resolve`. Set
# them via `supabase secrets set KEY=value` for production, or in
# `supabase/.env` (gitignored) for local edge function dev. Do NOT prefix with
# VITE_ — the browser must never see the Google key.
#
# GOOGLE_MAPS_API_KEY=your_google_places_new_api_key
# PLACES_API_SOFT_CAP=5000
# PLACES_API_HARD_CAP=6000
# PLACES_API_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...   # optional
